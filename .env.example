# ======================================================================
# DJANGO APPLICATION CONFIGURATION
# Variables consumed by the Django backend and related worker services.
# These values are environment-specific and should not be committed with
# real credentials in version control.
# ======================================================================

# Django settings module. For development, use config.settings.dev.
# Production should set config.settings.prod or another environment.
DJANGO_SETTINGS_MODULE=config.settings.dev

# Secret key for Django cryptographic signing. The value here must be
# replaced locally and overridden in production environments.
DJANGO_SECRET_KEY=replace_me_with_a_very_secret_value

# Enables Django's debug mode. This should always be explicitly set to
# False in production.
DJANGO_DEBUG=True

# Comma-separated list of allowable hosts for Django. Override with
# production domain names in deployed environments.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1


# ======================================================================
# DATABASE CONFIGURATION
# Django uses a single DJANGO_DATABASE_URL instead of multiple discrete
# database variables. django-environ will parse and load this value.
#
# Local development (Postgres running on the host machine):
#   postgres://user:password@host.docker.internal:5432/dbname
#
# Production (remote or managed Postgres instance):
#   postgres://prod_user:prod_pass@db.example.com:5432/prod_db
# ======================================================================

DJANGO_DATABASE_URL=postgres://user:password@host.docker.internal:5432/dbname


# ======================================================================
# OPTIONAL CACHING / QUEUE BACKENDS (PLACEHOLDERS)
# These may be introduced when Celery, Redis, or task workers are added.
# They are commented out for now but preserved for future expansion.
#
# DJANGO_CACHE_URL=redis://localhost:6379/1
# DJANGO_BROKER_URL=redis://localhost:6379/2
# ======================================================================


# ======================================================================
# FRONTEND CONFIGURATION (PLACEHOLDER)
# Future frontend services (React/Vite) may use service-prefixed
# variables for API routing or environment selection.
#
# FRONTEND_API_URL=http://localhost:8000
# FRONTEND_ENV=development
# ======================================================================


# ======================================================================
# SECURITY / LOGGING / DEPLOYMENT (PLACEHOLDERS)
# Extend these as the application evolves or integrates with other
# infrastructure components.
#
# DJANGO_LOG_LEVEL=INFO
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com
# DJANGO_ALLOWED_CIDR=10.0.0.0/8
# ======================================================================
